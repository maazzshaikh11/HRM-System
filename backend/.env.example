# Supabase Credentials Template

# The PostgreSQL connection string for Prisma.
# Get this from your Supabase Project Settings -> Database -> Connection string -> URI
DATABASE_URL="postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# The direct connection string for Prisma migrations.
# Note the port is 5432 and no pgbouncer flag.
DIRECT_URL="postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# The URL of your Supabase project (Project Settings -> API)
SUPABASE_URL="https://[PROJECT-REF].supabase.co"

# Your anon key (Project Settings -> API)
SUPABASE_ANON_KEY="your-anon-key-here"

# Your service role key (Project Settings -> API) - KEEP THIS SECURE, NEVER SHARE
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"
