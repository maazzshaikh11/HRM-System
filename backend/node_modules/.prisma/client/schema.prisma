generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model users {
  id          Int      @id @default(autoincrement())
  employee_id String   @unique
  name        String
  email       String   @unique
  password    String
  role        String // "Admin" or "Employee" or "HR"
  created_at  DateTime @default(now())

  profile           profiles?
  attendance        attendance[]
  leave_requests    leave_requests[]
  salary_structures salary_structures[]
  notifications     notifications[]

  department_id Int?
  department    departments? @relation(fields: [department_id], references: [id])
}

model profiles {
  id             Int       @id // Foreign key to users.id
  address        String?
  phone          String?
  joining_date   DateTime?
  designation    String?
  photo_url      String?
  documents_urls String[]  @default([])

  user users @relation(fields: [id], references: [id], onDelete: Cascade)
}

model attendance {
  id        Int       @id @default(autoincrement())
  user_id   Int
  date      DateTime  @db.Date
  check_in  DateTime?
  check_out DateTime?
  hours     Float?
  status    String // e.g., "Present", "Absent", "Half Day"

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, date])
}

model leave_requests {
  id        Int      @id @default(autoincrement())
  user_id   Int
  type      String // e.g., "Sick", "Casual", "Annual"
  from_date DateTime @db.Date
  to_date   DateTime @db.Date
  reason    String
  status    String   @default("Pending") // "Pending", "Approved", "Rejected"
  comments  String?

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model salary_structures {
  id              Int   @id @default(autoincrement())
  user_id         Int
  basic           Float
  hra             Float
  lta             Float
  pf              Float
  other_allowance Float
  deductions      Float

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model roles {
  id   Int    @id @default(autoincrement())
  name String @unique
}

model departments {
  id    Int     @id @default(autoincrement())
  name  String  @unique
  users users[]
}

model notifications {
  id         Int      @id @default(autoincrement())
  user_id    Int
  message    String
  read_flag  Boolean  @default(false)
  created_at DateTime @default(now())

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}
